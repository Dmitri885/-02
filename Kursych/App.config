<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<!-- ДОБАВЬ ЭТУ СЕКЦИЮ -->
	<system.diagnostics>
		<sources>
			<source name="System.Transactions" switchValue="Off">
				<listeners>
					<remove name="Default" />
				</listeners>
			</source>
		</sources>
	</system.diagnostics>

	<appSettings>
		<add key="DefaultAdminLogin" value="admin"/>
		<add key="DefaultAdminPassword" value="admin"/>
		<add key="InactivityTimeoutSeconds" value="30"/>
	</appSettings>

	<connectionStrings>
		<add name="MySQLConnection"
			 connectionString="Server=localhost;Database=kursych;Uid=root;Pwd=root;"
			 providerName="MySql.Data.MySqlClient" />
	</connectionStrings>
</configuration>